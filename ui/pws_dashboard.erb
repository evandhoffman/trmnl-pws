<!-- https://trmnl.com/plugin_settings/18870/markup/edit?size=markup_full -->
<div class="view view--full">
  <div class="layout layout--col gap--space-between">
    <div class="grid">
      <div class="col col--span-3 col--end">
        <div class="item h--full">
          <div class="content">
            <span class="value value--xxxlarge">{{tempf | round}}°F</span>
            <span class="label w--full">Outdoor Temperature</span>
            <div style="margin-top: 16px; margin-bottom: 8px;">
              <svg viewBox="0 0 312 108" style="width: 100%; height: 72px; display: block;">
                <polyline
                  points="{{temp_sparkline_points}}"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="4"
                  stroke-linecap="round"
                  stroke-linejoin="round" />
              </svg>
            </div>
            <span class="value value--small">Inside {{tempinf | round}}°F</span>
            <span class="label">Indoor humidity {{humidityin}}%</span>
          </div>
        </div>
      </div>
      <div class="col col--span-6 col--end">
        <div class="grid grid--cols-2 gap--medium">
          <div class="item">
            <div class="content">
              <span class="value value--xsmall">Pressure {{baromrelin}} inHg</span>
              <span class="label">{{pressure_trend_label}} over 3h</span>
            </div>
          </div>
          <div class="item">
            <div class="content">
              <span class="value value--xsmall">{{wind_compact}}</span>
              <span class="label">{{wind_gust_pretty}}</span>
            </div>
          </div>
          <div class="item">
            <div class="content">
              <span class="value value--xsmall">{{feelsLike | round}}°</span>
              <span class="label">Feels Like</span>
            </div>
          </div>
          <div class="item">
            <div class="content">
              <span class="value value--xsmall">{{humidity}}%</span>
              <span class="label">Humidity</span>
            </div>
          </div>
          <div class="item">
            <div class="content">
              <span class="value value--xsmall">{{dewPoint | round}}°</span>
              <span class="label">Dew Point</span>
            </div>
          </div>
          <div class="item">
            <div class="content">
              <span class="value value--xsmall">{{uv | round}}</span>
              <span class="label">UV Index</span>
            </div>
          </div>
          <div class="item">
            <div class="content">
              <span class="value value--xsmall">{{solarradiation | round}} W/m²</span>
              <span class="label">Solar Radiation</span>
            </div>
          </div>
          <div class="item">
            <div class="content">
              <span class="value value--xsmall">{{dailyrainin | round: 2}} in</span>
              <span class="label">Rain Today</span>
            </div>
          </div>
          <div class="item" style="grid-column: span 2;">
            <div class="content">
              <span class="value value--xsmall">{{last_rain_date_pretty}}</span>
              <span class="label">Last Rain</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="title_bar">
      <img class="image" src="https://cdn-icons-png.flaticon.com/512/16342/16342339.png" />
      <h1 class="title">Last updated: {{date_pretty}}</h1>
      <span class="instance">{{trmnl['plugin_settings']['instance_name']}}</span>
    </div>
  </div>
</div>
