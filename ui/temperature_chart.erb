<!-- https://trmnl.com/plugin_settings/25545/markup/edit?size=markup_full -->
<script src="https://code.highcharts.com/highcharts.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartkick@5.0.1/dist/chartkick.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/moment.js/2.29.4/moment.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/moment-timezone/0.5.40/moment-timezone-with-data.min.js"></script>

  <div class="view view--full">
    <div class="grid grid--cols-3 gap--small" style="margin-bottom: 6px;">
      <div class="item">
        <div class="content">
          <span class="value value--xsmall">{{temp_low_value}}</span>
          <span class="label">Low @ {{temp_low_time}}</span>
        </div>
      </div>
      <div class="item">
        <div class="content">
          <span class="value value--xsmall">{{temp_high_value}}</span>
          <span class="label">High @ {{temp_high_time}}</span>
        </div>
      </div>
      <div class="item">
        <div class="content">
          <span class="value value--xsmall">{{temp_last_value}}</span>
          <span class="label">Last @ {{temp_last_time}}</span>
        </div>
      </div>
    </div>

    <div id="weather-chart" style="width: 100%; height: 348px;"></div>

    <div class="title_bar">
      <img class="image" src="https://cdn-icons-png.flaticon.com/512/16342/16342339.png" />
      <span class="title">Weather Station</span>
      <span class="instance">Temperature @ {{current_timestamp}}</span>
    </div>
  </div>

  <script type="text/javascript">
    var data = {{js_temperature_data}};
    var indoorData = {{js_indoor_temperature_data}};
    var solarEvents = {{js_solar_events}};
    var allChartPoints = data.concat(indoorData);
    var xMin = allChartPoints.length ? Math.min.apply(null, allChartPoints.map(function(point) { return point[0]; })) : null;
    var xMax = allChartPoints.length ? Math.max.apply(null, allChartPoints.map(function(point) { return point[0]; })) : null;
    var visibleSolarEvents = solarEvents.filter(function(event) {
      return xMin !== null && xMax !== null && event.timestamp_ms >= xMin && event.timestamp_ms <= xMax;
    });

    // Find temperature range for better y-axis setup
    const temperatures = allChartPoints.map(point => point[1]);
    let minTemp = Math.min(...temperatures);
    let maxTemp = Math.max(...temperatures);

    // Add 5-degree buffer as requested
    minTemp = Math.floor(minTemp) - 3;
    maxTemp = Math.ceil(maxTemp) + 3;

    function buildFreezingHatchLines(minimumTemp) {
      if (minimumTemp >= 32) {
        return [];
      }

      return [{
        value: 32,
        color: "black",
        width: 2,
        dashStyle: "Dash",
        zIndex: 1,
        label: {
          text: "Freezing (32°F)",
          align: "right",
          x: -10,
          style: {
            color: "black",
            fontWeight: "bold"
          }
        }
      }];
    }

    const freezingHatchLines = buildFreezingHatchLines(minTemp);
    const solarEventSeries = visibleSolarEvents.map(function(event) {
      return {
        name: event.label,
        data: [
          [event.timestamp_ms, minTemp],
          [event.timestamp_ms, maxTemp]
        ],
        color: "#000000",
        lineWidth: event.label === "Noon" ? 2 : 1,
        dashStyle: event.label === "Noon" ? "Solid" : "ShortDot",
        marker: { enabled: false },
        enableMouseTracking: false,
        showInLegend: false,
        dataLabels: {
          enabled: false
        }
      };
    }).concat(visibleSolarEvents.map(function(event) {
      return {
        type: "scatter",
        name: event.label,
        data: [[event.timestamp_ms, minTemp + ((maxTemp - minTemp) * 0.06)]],
        color: "#000000",
        marker: {
          enabled: false
        },
        enableMouseTracking: false,
        showInLegend: false,
        dataLabels: {
          enabled: true,
          formatter: function() {
            return event.label;
          },
          align: "left",
          x: 2,
          y: 0,
          style: {
            color: "#000000",
            fontSize: "11px",
            textOutline: "none"
          }
        }
      };
    }));

    // recommended configs to achieve the e-ink friendly aesthetic
    var createChart = function() {
      new Chartkick["LineChart"](
        "weather-chart",
        solarEventSeries.concat([
          {name: "Outdoor", data: data, dashStyle: "solid"},
          {name: "Indoor", data: indoorData, dashStyle: "shortdash"}
        ]).filter(series => series.data.length > 0),
        {
          adapter: "highcharts",
          suffix: "°F",
          thousands: ",",
          points: false,
          colors: ["black", "#666666"],
          curve: true,
          xtype: "datetime",
          library: {
            time: {
              timezone: "{{display_timezone}}"
            },
            chart: {
              title: {
                text: null
              },
              height: 348,
              spacingTop: 6,
              spacingBottom: 8,
              spacingLeft: 0,
              spacingRight: 0,
              style: {
                fontFamily: "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif"
              }
            },
            plotOptions: {
              series: {
                animation: false,
                lineWidth: 2,
                marker: {
                  enabled: false
                },
                showInLegend: true,
              }
            },
            legend: {
              enabled: indoorData.length > 0
            },
            yAxis: {
              title: {
                text: 'Temperature (°F)'
              },
              min: minTemp,
              max: maxTemp,
              labels: {
                style: {
                  fontSize: "16px",
                  color: "#000000"
                }
              },
              gridLineDashStyle: "shortdot",
              gridLineWidth: 1,
              gridLineColor: "#000000",
              plotLines: freezingHatchLines
            },
            xAxis: {
              type: "datetime",
              min: xMin,
              max: xMax,
              labels: {
                style: {
                  fontSize: "16px",
                  color: "#000000"
                },
                formatter: function() {
                  return moment.tz(this.value, "{{display_timezone}}").format("HH:mm");
                }
              },
              lineWidth: 0,
              gridLineDashStyle: "dot",
              tickWidth: 1,
              tickLength: 0,
              gridLineWidth: 1,
              gridLineColor: "#000000",
              tickPixelInterval: 60
            }
          }
        });
    };


    // ensure your chart loads before plugin render is generated
    if ("Chartkick" in window) {
      createChart();
    } else {
      window.addEventListener("chartkick:load", createChart, true);
    }
  </script>
