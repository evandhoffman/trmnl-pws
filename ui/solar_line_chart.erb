<!-- https://trmnl.com/plugin_settings/27170/markup/edit?size=markup_full -->
<script src="https://code.highcharts.com/highcharts.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartkick@5.0.1/dist/chartkick.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/moment.js/2.29.4/moment.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/moment-timezone/0.5.40/moment-timezone-with-data.min.js"></script>

<div class="view view--full">
  <div class="layout layout--col gap--space-between">

    <div class="grid grid--cols-4" style="text-align: center;">
      <div class="item">
        <div class="content">
          <span class="title title--small">{{str_daily_energy}} kWh</span>
          <span class="description">Today's Generation</span>
        </div>
      </div>
      <div class="item">
        <div class="content">
          <span class="title title--small">{{peak_solar_kw}} kW @ {{peak_solar_time}}</span>
          <span class="description">Peak Today</span>
        </div>
      </div>
      <div class="item">
        <div class="content">
          <span class="title title--small" id="current-solar">--</span>
          <span class="description">Current Solar</span>
        </div>
      </div>
      <div class="item">
        <div class="content">
          <span class="title title--small" id="current-load">--</span>
          <span class="description">Current Load</span>
        </div>
      </div>
    </div>

    <div id="solar-chart" style="width: 100%"></div>

  </div>

  <div class="title_bar">
    <img class="image" src="https://cdn-icons-png.flaticon.com/512/16342/16342339.png" />
    <span class="title">Solar Power Monitor</span>
    <span class="instance">Power Stats @ {{current_timestamp}}</span>
  </div>
</div>

    <script type="text/javascript">
        // Empty data arrays to be filled in later
        var gridData = {{str_bellmore_grid_power}};
        var loadData = {{str_bellmore_load_power}};
        var solarData = {{str_bellmore_solar_power}};
        var solarEvents = {{js_solar_events}};
        var allSeriesPoints = gridData.concat(loadData).concat(solarData);
        var minPower = allSeriesPoints.length ? Math.min.apply(null, allSeriesPoints.map(function(point) { return point[1]; })) : 0;
        var maxPower = allSeriesPoints.length ? Math.max.apply(null, allSeriesPoints.map(function(point) { return point[1]; })) : 1;
        var yPadding = Math.max((maxPower - minPower) * 0.1, 0.5);
        minPower = Math.floor(minPower - yPadding);
        maxPower = Math.ceil(maxPower + yPadding);
        var markerLabelY = minPower + ((maxPower - minPower) * 0.06);
        var solarEventSeries = solarEvents.map(function(event) {
            return {
                name: event.label,
                data: [
                    [event.timestamp_ms, minPower],
                    [event.timestamp_ms, maxPower]
                ],
                color: "#000000",
                lineWidth: event.label === "Noon" ? 2 : 1,
                dashStyle: event.label === "Noon" ? "Solid" : "ShortDot",
                marker: { enabled: false },
                enableMouseTracking: false,
                showInLegend: false,
                dataLabels: {
                    enabled: false
                }
            };
        }).concat(solarEvents.map(function(event) {
            return {
                type: "scatter",
                name: event.label,
                data: [[event.timestamp_ms, markerLabelY]],
                color: "#000000",
                marker: {
                    enabled: false
                },
                enableMouseTracking: false,
                showInLegend: false,
                dataLabels: {
                    enabled: true,
                    formatter: function() {
                        return event.label;
                    },
                    align: "left",
                    x: 2,
                    y: 0,
                    style: {
                        color: "#000000",
                        fontSize: "11px",
                        textOutline: "none"
                    }
                }
            };
        }));

        // recommended configs to achieve the e-ink friendly aesthetic
        var createChart = function() {
            new Chartkick["LineChart"](
            "solar-chart",
            solarEventSeries.concat([
                {name: "Grid Power", data: gridData, dashStyle: "dash"},
                {name: "House load", data: loadData, dashStyle: "dot"},
                {name: "Solar Generation", data: solarData, dashStyle: "solid"},
            ]),
            {
                adapter: "highcharts",
                suffix: "kW",
                thousands: ",",
                points: false,
                colors: ["#000000", "#000000", "#000000", "#000000"],
                curve: true,
                // Use native Highcharts datetime formatting
                xtype: "datetime",
                library: {
                    time: {
                        timezone: "{{display_timezone}}"
                    },
                    chart: {
                        title: {
                          text: 'Rooftop Solar Power'
                        },
                        height: 330,
                        style: {
                            fontFamily: "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif"
                        }
                    },
                    plotOptions: {
                        series: {
                            animation: false,
                            lineWidth: 3,
                            marker: {
                                enabled: false
                            }
                        }
                    },
                    legend: {
                        enabled: true,
                        itemStyle: {
                            color: '#000000',
                            fontWeight: 'normal'
                        }
                    },
                    yAxis: {
                        title: {
                          text: 'Power (kW)'
                        },
                        min: minPower,
                        max: maxPower,
                        labels: {
                            style: {
                                fontSize: "16px",
                                color: "#000000"
                            }
                        },
                        gridLineDashStyle: "shortdot",
                        gridLineWidth: 1,
                        gridLineColor: "#000000"
                    },
                    xAxis: {
                        type: "datetime",
                        labels: {
                            style: {
                                fontSize: "16px",
                                color: "#000000"
                            },
                            formatter: function() {
                                return moment.tz(this.value, "{{display_timezone}}").format("HH:mm");
                            }
                        },
                        lineWidth: 0,
                        gridLineDashStyle: "dot",
                        tickWidth: 1,
                        tickLength: 0,
                        gridLineWidth: 1,
                        gridLineColor: "#000000",
                        tickPixelInterval: 60
                    }
                }
            });
        };

        // Populate current values from last data point in each series
        var lastOf = function(arr) { return arr.length ? arr[arr.length - 1][1] : null; };
        var currentSolar = lastOf(solarData);
        var currentLoad  = lastOf(loadData);
        if (currentSolar !== null) document.getElementById("current-solar").textContent = currentSolar + " kW";
        if (currentLoad  !== null) document.getElementById("current-load").textContent  = currentLoad  + " kW";

        // ensure your chart loads before plugin render is generated
        if ("Chartkick" in window) {
            createChart();
        } else {
            window.addEventListener("chartkick:load", createChart, true);
        }
    </script>
