<!-- https://trmnl.com/plugin_settings/27170/markup/edit?size=markup_full -->
<script src="https://code.highcharts.com/highcharts.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartkick@5.0.1/dist/chartkick.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/moment.js/2.29.4/moment.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/moment-timezone/0.5.40/moment-timezone-with-data.min.js"></script>

                <div class="item">
                    <div class="meta"></div>
                    <div class="content">
                        <span class="title title--small">{{str_daily_energy}} kWh</span>
                        <span class="description">Today's Solar Generation</span>
                    </div>
                </div>

                <div class="item">
                    <div class="meta"></div>
                    <div class="content">
                        <span class="title title--small">{{peak_solar_kw}} kW @ {{peak_solar_time}}</span>
                        <span class="description">Peak Solar Today</span>
                    </div>
                </div>

            <div id="solar-chart" style="width: 100%"></div>

        <div class="title_bar">
            <svg class="image" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 3L4 6v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V6l-8-3zm0 2.87L17 8.25V12c0 3.9-2.55 7.46-6 8.6-3.45-1.14-6-4.7-6-8.6V8.25l6-2.38z" fill="black"/>
            </svg>
            <span class="title">Solar Power Monitor</span>
            <span class="instance">Power Stats @ {{current_timestamp}}</span>
        </div>
    </div>

    <script type="text/javascript">
        // Empty data arrays to be filled in later
        var gridData = {{str_bellmore_grid_power}};
        var loadData = {{str_bellmore_load_power}};
        var solarData = {{str_bellmore_solar_power}};

        // recommended configs to achieve the e-ink friendly aesthetic
        var createChart = function() {
            new Chartkick["LineChart"](
            "solar-chart",
            [
                {name: "Grid Power", data: gridData, dashStyle: "dash"},
                {name: "House load", data: loadData, dashStyle: "dot"},
                {name: "Solar Generation", data: solarData, dashStyle: "solid"},
            ],
            {
                adapter: "highcharts",
                suffix: "kW",
                thousands: ",",
                points: false,
                colors: ["#000000", "#000000", "#000000", "#000000"],
                curve: true,
                // Use native Highcharts datetime formatting
                xtype: "datetime",
                library: {
                    time: {
                        timezone: "{{display_timezone}}"
                    },
                    chart: {
                        title: {
                          text: 'Rooftop Solar Power'
                        },
                        height: 330,
                        style: {
                            fontFamily: "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif"
                        }
                    },
                    plotOptions: {
                        series: {
                            animation: false,
                            lineWidth: 3,
                            marker: {
                                enabled: false
                            }
                        }
                    },
                    legend: {
                        enabled: true,
                        itemStyle: {
                            color: '#000000',
                            fontWeight: 'normal'
                        }
                    },
                    yAxis: {
                        title: {
                          text: 'Power (kW)'
                        },
                        labels: {
                            style: {
                                fontSize: "16px",
                                color: "#000000"
                            }
                        },
                        gridLineDashStyle: "shortdot",
                        gridLineWidth: 1,
                        gridLineColor: "#000000"
                    },
                    xAxis: {
                        type: "datetime",
                        labels: {
                            style: {
                                fontSize: "16px",
                                color: "#000000"
                            },
                            formatter: function() {
                                return moment.tz(this.value, "{{display_timezone}}").format("HH:mm");
                            }
                        },
                        lineWidth: 0,
                        gridLineDashStyle: "dot",
                        tickWidth: 1,
                        tickLength: 0,
                        gridLineWidth: 1,
                        gridLineColor: "#000000",
                        tickPixelInterval: 60
                    }
                }
            });
        };

        // ensure your chart loads before plugin render is generated
        if ("Chartkick" in window) {
            createChart();
        } else {
            window.addEventListener("chartkick:load", createChart, true);
        }
    </script>
